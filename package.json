{
  "name": "certificate-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "doctor": "npx react-doctor@latest",
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs",
    "storybook": "dotenv -e .env.local -- storybook dev -p 6006",
    "build-storybook": "dotenv -e .env.local -- storybook build",
    "gen:types": "dotenv -e .env.local -- sh -c 'supabase gen types typescript --linked --schema public' > database.types.ts",
    "supabase:db:push": "supabase db push",
    "supabase:db:push:seed": "supabase db push --include-seed",
    "supabase:functions:deploy": "supabase functions deploy",
    "supabase:seed:files": "dotenv -e .env.local -- npx tsx scripts/seed-upload-files.ts",
    "supabase:reset": "supabase db reset --linked"
  },
  "dependencies": {
