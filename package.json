    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "posthog-js": "^1.380.0",
    "posthog-node": "^5.36.1",
    "qrcode-with-logos": "^1.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
